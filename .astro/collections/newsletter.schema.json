{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "excerpt": {
      "type": "string"
    },
    "publishDate": {
      "type": "string",
      "format": "date-time"
    },
    "issue": {
      "type": "number"
    },
    "draft": {
      "type": "boolean"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "ignoreTitleTemplate": {
          "type": "boolean"
        },
        "canonical": {
          "type": "string",
          "format": "uri"
        },
        "robots": {
          "type": "object",
          "properties": {
            "index": {
              "type": "boolean"
            },
            "follow": {
              "type": "boolean"
            }
          }
        },
        "description": {
          "type": "string"
        },
        "openGraph": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string"
            },
            "siteName": {
              "type": "string"
            },
            "images": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string"
                  },
                  "width": {
                    "type": "number"
                  },
                  "height": {
                    "type": "number"
                  }
                },
                "required": [
                  "url"
                ]
              }
            },
            "locale": {
              "type": "string"
            },
            "type": {
              "type": "string"
            }
          }
        },
        "twitter": {
          "type": "object",
          "properties": {
            "handle": {
              "type": "string"
            },
            "site": {
              "type": "string"
            },
            "cardType": {
              "type": "string"
            }
          }
        }
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "publishDate"
  ]
}