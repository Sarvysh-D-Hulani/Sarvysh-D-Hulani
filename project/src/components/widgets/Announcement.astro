---
import { Icon } from 'astro-icon/components';
---

<div class="hidden md:flex items-center gap-2 overflow-hidden px-4 py-2 relative gradient-deep-sea text-ivory/70">
  <!-- Subtle shimmer overlay -->
  <div class="absolute inset-0 pointer-events-none opacity-30 animate-shimmer" style="background: linear-gradient(90deg, transparent, rgba(218, 165, 32, 0.08), transparent); background-size: 200% 100%;" aria-hidden="true"></div>
  <span class="relative bg-gradient-to-r from-gold to-amber-400 text-midnight font-bold px-2 py-0.5 text-xs inline-block rounded">WELCOME</span>
  <a href="/about" class="relative text-gold hover:text-amber-300 transition font-medium">
    Welcome to my corner of the internet
  </a>
  <Icon name="tabler:arrow-right" class="relative w-3.5 h-3.5 ml-1 text-gold" />
</div>
