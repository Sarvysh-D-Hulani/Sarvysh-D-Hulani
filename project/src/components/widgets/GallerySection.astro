---
import { Icon } from 'astro-icon/components';
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';

export interface GalleryItem {
  title: string;
  image: string;
  caption?: string;
  album?: string;
  category?: string;
  date?: Date;
}

export interface Props {
  items?: GalleryItem[];
  title?: string;
  subtitle?: string;
  tagline?: string;
  limit?: number;
}

const {
  items = [],
  title = 'Gallery',
  subtitle = 'Moments from campus, travels, and the everyday life that makes the journey real.',
  tagline = 'Gallery',
  limit = 6,
} = Astro.props;

const limitedItems = items.slice(0, limit);
---

<section class="relative py-20 md:py-28 bg-page dark:bg-midnight overflow-hidden">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Section header with number badge -->
    <div class="flex flex-col items-center text-center mb-14 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-5xl md:text-6xl font-bold tracking-tighter gradient-text opacity-20 select-none">06</span>
        <span class="h-px w-12 bg-gradient-to-r from-sapphire to-cyan2"></span>
        <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text">{tagline}</p>
      </div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter text-heading mb-4">{title}</h2>
      <p class="text-lg text-muted max-w-2xl mx-auto">{subtitle}</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
      {limitedItems.map((item, index) => (
        <div
          class={`group relative rounded-2xl overflow-hidden cursor-pointer shadow-lg shadow-navy/5 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-scale-in ${index === 0 ? 'col-span-2 row-span-2 md:col-span-2 md:row-span-2' : ''}`}
          style={`animation-delay: ${index * 60}ms;`}
        >
          <Image
            src={item.image}
            alt={item.title}
            layout="responsive"
            class={`w-full ${index === 0 ? 'h-full min-h-[320px] md:min-h-[440px]' : 'h-44 md:h-52'} object-cover transition-transform duration-700 ease-out group-hover:scale-110`}
          />
          <!-- Dramatic gradient overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-midnight/90 via-midnight/20 to-transparent opacity-50 group-hover:opacity-90 transition-opacity duration-500"></div>
          <!-- Caption reveal -->
          <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-500">
            {item.category && (
              <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-semibold text-white bg-gradient-to-r from-sapphire to-cyan2 mb-2">
                {item.category}
              </span>
            )}
            <p class="text-base font-bold text-ivory">{item.title}</p>
            {item.caption && <p class="text-sm text-ivory/70 mt-1">{item.caption}</p>}
          </div>
          <!-- Subtle border highlight on hover -->
          <div class="absolute inset-0 rounded-2xl ring-2 ring-sapphire/0 group-hover:ring-sapphire/30 transition-all duration-500"></div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a
        href="/gallery"
        class="group inline-flex items-center gap-2 px-7 py-3.5 rounded-full border-2 border-sapphire/20 hover:border-sapphire/40 text-sapphire dark:text-cyan2 font-semibold transition-all duration-300 hover:shadow-lg hover:shadow-sapphire/10 hover:-translate-y-0.5"
      >
        View Full Gallery
        <Icon name="tabler:arrow-right" class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1.5" />
      </a>
    </div>
  </div>
</section>
