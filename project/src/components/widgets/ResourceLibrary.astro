---
import { Icon } from 'astro-icon/components';
import Button from '~/components/ui/Button.astro';

export interface ResourceItem {
  title: string;
  description?: string;
  category?: string;
  difficulty?: string;
  recommendation?: string;
  personalNotes?: string;
  link?: string;
}

export interface Props {
  items?: ResourceItem[];
  title?: string;
  subtitle?: string;
  tagline?: string;
  limit?: number;
}

const {
  items = [],
  title = 'Resource Library',
  subtitle = 'Curated learning resources that have shaped my thinking. Each one comes with personal notes.',
  tagline = 'Resources',
  limit = 6,
} = Astro.props;

const limitedItems = items.slice(0, limit);

const recColors: Record<string, string> = {
  Essential: 'bg-gradient-to-r from-gold to-amber-400 text-midnight',
  'Highly Recommended': 'bg-gradient-to-r from-sapphire to-cyan2 text-white',
  Recommended: 'bg-gradient-to-r from-cyan2 to-emerald2 text-white',
};

const diffColors: Record<string, string> = {
  Beginner: 'bg-emerald2/10 text-emerald2',
  Intermediate: 'bg-sapphire/10 text-sapphire',
  Advanced: 'bg-gold/10 text-gold',
};
---

<section class="relative py-20 md:py-28 bg-section-alt overflow-hidden">
  <div class="absolute top-0 left-1/4 w-[400px] h-[300px] rounded-full bg-sapphire/5 blur-[120px] pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Section header with number badge -->
    <div class="flex flex-col items-center text-center mb-14 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-5xl md:text-6xl font-bold tracking-tighter gradient-text opacity-20 select-none">05</span>
        <span class="h-px w-12 bg-gradient-to-r from-sapphire to-cyan2"></span>
        <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text">{tagline}</p>
      </div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter text-heading mb-4">{title}</h2>
      <p class="text-lg text-muted max-w-2xl mx-auto">{subtitle}</p>
    </div>

    <div class="grid md:grid-cols-2 gap-5 md:gap-6">
      {limitedItems.map((item, index) => (
        <div
          class="premium-card card-glow rounded-2xl p-6 md:p-7 group intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
          style={`animation-delay: ${index * 80}ms;`}
        >
          <div class="flex items-start justify-between gap-4 mb-4">
            <div class="flex items-center gap-2">
              {item.category && (
                <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-navy/5 dark:bg-sapphire/10 text-sapphire dark:text-cyan2">
                  {item.category}
                </span>
              )}
              {item.difficulty && (
                <span class={`px-2.5 py-0.5 rounded-full text-xs font-medium ${diffColors[item.difficulty] || diffColors.Beginner}`}>
                  {item.difficulty}
                </span>
              )}
            </div>
            {item.recommendation && (
              <span class={`px-3 py-1 rounded-full text-xs font-bold shadow-sm ${recColors[item.recommendation] || recColors.Recommended}`}>
                {item.recommendation}
              </span>
            )}
          </div>

          <h3 class="text-lg font-bold text-heading mb-2 group-hover:text-sapphire transition-colors duration-300">{item.title}</h3>
          {item.description && <p class="text-sm text-muted leading-relaxed mb-4">{item.description}</p>}

          {item.personalNotes && (
            <div class="relative pl-5 mb-4 border-l-2 border-gold/50">
              <Icon name="tabler:quote" class="absolute -left-2 top-0 w-4 h-4 text-gold/40" />
              <p class="text-sm text-muted italic leading-relaxed">{item.personalNotes}</p>
            </div>
          )}

          {item.link && (
            <a
              href={item.link}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm font-semibold text-sapphire dark:text-cyan2 hover:gap-2.5 transition-all duration-300"
            >
              Visit Resource
              <Icon name="tabler:external-link" class="w-4 h-4" />
            </a>
          )}
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a
        href="/resources"
        class="group inline-flex items-center gap-2 px-7 py-3.5 rounded-full border-2 border-sapphire/20 hover:border-sapphire/40 text-sapphire dark:text-cyan2 font-semibold transition-all duration-300 hover:shadow-lg hover:shadow-sapphire/10 hover:-translate-y-0.5"
      >
        <Icon name="tabler:books" class="w-4 h-4" />
        Browse All Resources
        <Icon name="tabler:arrow-right" class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1.5" />
      </a>
    </div>
  </div>
</section>
