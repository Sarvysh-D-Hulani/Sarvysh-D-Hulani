---
import PageLayout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import { fetchKnowledge } from '~/utils/collections';

const items = await fetchKnowledge();
const categories = [...new Set(items.map((i) => i.category).filter(Boolean))];
const metadata = {
  title: 'Knowledge Hub',
  description: 'A searchable collection of everything I learn. Notes, research, and insights.',
};

const categoryColors: Record<string, string> = {
  AI: 'from-sapphire to-cyan2',
  Engineering: 'from-navy to-sapphire',
  Finance: 'from-emerald2 to-cyan2',
  Consulting: 'from-gold to-amber-400',
  Productivity: 'from-cyan2 to-sapphire',
  Career: 'from-sapphire to-gold',
};

const categoryAccent: Record<string, string> = {
  AI: 'bg-sapphire',
  Engineering: 'bg-navy',
  Finance: 'bg-emerald2',
  Consulting: 'bg-gold',
  Productivity: 'bg-cyan2',
  Career: 'bg-sapphire',
};

const difficultyColors: Record<string, string> = {
  Beginner: 'bg-emerald2/10 text-emerald2',
  Intermediate: 'bg-sapphire/10 text-sapphire',
  Advanced: 'bg-gold/10 text-gold',
};
---

<PageLayout metadata={metadata}>
  <!-- Hero header -->
  <section class="relative pt-20 md:pt-28 pb-16 md:pb-20 bg-gradient-to-b from-section-alt to-page dark:from-midnight dark:to-midnight overflow-hidden">
    <div class="absolute top-0 left-1/4 w-[400px] h-[300px] rounded-full bg-sapphire/5 blur-[120px] pointer-events-none" aria-hidden="true"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text mb-4 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">Knowledge</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter text-heading mb-6 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">Knowledge Hub</h1>
      <p class="text-lg lg:text-xl text-muted leading-relaxed max-w-2xl mx-auto intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">A searchable collection of everything I learn. Notes, research, and insights organized by topic.</p>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-page dark:bg-midnight">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      {categories.length > 0 && (
        <div class="flex flex-wrap justify-center gap-2 mb-12 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <button class="px-5 py-2.5 rounded-full text-sm font-medium bg-gradient-to-r from-sapphire to-cyan2 text-white shadow-sm transition-all" data-filter="all">All</button>
          {categories.map((cat) => (
            <button class="px-5 py-2.5 rounded-full text-sm font-medium bg-navy/5 dark:bg-sapphire/10 text-sapphire dark:text-cyan2 hover:bg-navy/10 hover:shadow-md transition-all" data-filter={cat}>{cat}</button>
          ))}
        </div>
      )}

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6" id="knowledge-grid">
        {items.map((item, index) => (
          <a
            href={`/knowledge-hub/${item.slug}`}
            class="premium-card card-glow rounded-2xl group block overflow-hidden intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
            style={`animation-delay: ${index * 80}ms;`}
            data-category={item.category || ''}
          >
            <!-- Top accent bar in category color -->
            {item.category && (
              <div class={`h-1 ${categoryAccent[item.category] || 'bg-sapphire'}`}></div>
            )}
            <div class="p-6">
              <div class="flex items-center justify-between mb-4">
                {item.category && (
                  <div class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold text-white bg-gradient-to-r ${categoryColors[item.category] || 'from-navy to-sapphire'} shadow-sm`}>
                    <Icon name="tabler:tag" class="w-3 h-3" />
                    {item.category}
                  </div>
                )}
                {item.difficulty && (
                  <span class={`px-2.5 py-0.5 rounded-full text-xs font-medium ${difficultyColors[item.difficulty] || difficultyColors.Beginner}`}>{item.difficulty}</span>
                )}
              </div>
              <h3 class="text-lg font-bold text-heading mb-2 group-hover:text-sapphire transition-colors duration-300">{item.title}</h3>
              {item.excerpt && <p class="text-sm text-muted leading-relaxed mb-4 line-clamp-3">{item.excerpt}</p>}
              {item.tags && item.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {item.tags.slice(0, 3).map((tag) => <span class="text-xs text-muted">#{tag}</span>)}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<script is:inline>
  document.querySelectorAll('[data-filter]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');
      document.querySelectorAll('[data-filter]').forEach((b) => {
        b.classList.remove('bg-gradient-to-r', 'from-sapphire', 'to-cyan2', 'text-white', 'shadow-sm');
        b.classList.add('bg-navy/5', 'dark:bg-sapphire/10', 'text-sapphire', 'dark:text-cyan2');
      });
      btn.classList.add('bg-gradient-to-r', 'from-sapphire', 'to-cyan2', 'text-white', 'shadow-sm');
      btn.classList.remove('bg-navy/5', 'dark:bg-sapphire/10', 'text-sapphire', 'dark:text-cyan2');
      document.querySelectorAll('#knowledge-grid > [data-category]').forEach((card) => {
        if (filter === 'all' || card.getAttribute('data-category') === filter) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
