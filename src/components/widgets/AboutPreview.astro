---
import { Icon } from 'astro-icon/components';

export interface Props {
  name?: string;
  story?: string;
  values?: Array<{ title: string; description: string }>;
  interests?: string[];
}

const { name = '', story = '', values = [], interests = [] } = Astro.props;

const valueIcons = ['tabler:compass', 'tabler:bolt', 'tabler:heart', 'tabler:bulb'];
const valueGradients = [
  'from-sapphire to-cyan2',
  'from-cyan2 to-emerald2',
  'from-gold to-amber-400',
  'from-sapphire to-gold',
];
---

<section class="relative py-20 md:py-28 bg-page dark:bg-midnight overflow-hidden">
  <div
    class="absolute top-0 left-1/4 w-[400px] h-[300px] rounded-full bg-sapphire/5 blur-[120px] pointer-events-none"
    aria-hidden="true"
  >
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Section header with number badge -->
    <div
      class="flex flex-col items-center text-center mb-14 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
    >
      <div class="flex items-center gap-3 mb-4">
        <span class="text-5xl md:text-6xl font-bold tracking-tighter gradient-text opacity-20 select-none">09</span>
        <span class="h-px w-12 bg-gradient-to-r from-sapphire to-cyan2"></span>
        <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text">About</p>
      </div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter text-heading mb-4">
        The beginning of a story
      </h2>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Story with large quote treatment -->
      <div class="intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
        {
          story && (
            <blockquote class="relative pl-6 border-l-4 border-gold mb-8">
              <Icon name="tabler:quote" class="absolute -left-3 -top-3 w-8 h-8 text-gold/30" />
              <p class="text-xl md:text-2xl text-heading font-medium leading-relaxed italic">{story}</p>
              {name && <footer class="mt-4 text-sm text-muted font-semibold tracking-wide">— {name}</footer>}
            </blockquote>
          )
        }

        {
          interests.length > 0 && (
            <div class="mb-8">
              <p class="text-xs font-bold tracking-[0.15em] uppercase text-muted mb-3">Interests</p>
              <div class="flex flex-wrap gap-2">
                {interests.slice(0, 6).map((interest) => (
                  <span class="px-3.5 py-1.5 rounded-full text-sm font-medium bg-navy/5 dark:bg-sapphire/10 text-sapphire dark:text-cyan2 border border-sapphire/10 dark:border-sapphire/20">
                    {interest}
                  </span>
                ))}
              </div>
            </div>
          )
        }

        <a
          href="/about"
          class="group inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-gradient-to-r from-sapphire to-cyan2 text-white font-semibold shadow-lg shadow-sapphire/20 hover:shadow-xl hover:shadow-sapphire/30 transition-all duration-300 hover:-translate-y-0.5"
        >
          Read My Full Story
          <Icon
            name="tabler:arrow-right"
            class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1.5"
          />
        </a>
      </div>

      <!-- Right: Values cards with gradient icon backgrounds -->
      <div
        class="grid sm:grid-cols-2 gap-4 md:gap-5 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
      >
        {
          values.slice(0, 4).map((value, index) => (
            <div
              class="premium-card card-glow rounded-2xl p-5 md:p-6 group"
              style={`animation-delay: ${index * 80}ms;`}
            >
              <div
                class={`w-12 h-12 rounded-2xl bg-gradient-to-br ${valueGradients[index % 4]} flex items-center justify-center mb-4 shadow-lg shadow-sapphire/10 transition-transform duration-300 group-hover:scale-110`}
              >
                <Icon name={valueIcons[index % 4]} class="w-6 h-6 text-white" />
              </div>
              <h3 class="text-base font-bold text-heading mb-1.5">{value.title}</h3>
              <p class="text-sm text-muted leading-relaxed">{value.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
