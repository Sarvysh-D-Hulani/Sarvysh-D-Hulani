---
import { Icon } from 'astro-icon/components';

export interface CredentialStat {
  label: string;
  value: string;
  icon?: string;
}

export interface Props {
  stats?: CredentialStat[];
}

const { stats = [] } = Astro.props;

if (!stats.length) {
  // Render nothing if no stats provided
}
---

{stats.length > 0 && (
  <div class="relative bg-midnight border-y border-ivory/[0.06] overflow-hidden">
    <!-- Subtle gradient top line -->
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-sapphire/50 to-transparent" aria-hidden="true"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-5">
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4 md:gap-x-14">
        {stats.map((stat, i) => (
          <div class="flex items-center gap-2.5 group">
            {stat.icon && (
              <Icon
                name={stat.icon}
                class="w-4 h-4 text-sapphire dark:text-cyan2 flex-shrink-0 transition-transform duration-300 group-hover:scale-110"
              />
            )}
            <div class="flex items-baseline gap-1.5">
              <span class="text-sm font-bold text-ivory tracking-tight">{stat.value}</span>
              <span class="text-xs text-ivory/40 font-medium uppercase tracking-wider">{stat.label}</span>
            </div>
            {/* Divider — hide on last item */}
            {i < stats.length - 1 && (
              <span class="hidden md:inline-block w-px h-4 bg-ivory/10 ml-8 md:ml-14 -mr-8 md:-mr-14 translate-x-1/2" aria-hidden="true"></span>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Subtle gradient bottom line -->
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan2/30 to-transparent" aria-hidden="true"></div>
  </div>
)}
