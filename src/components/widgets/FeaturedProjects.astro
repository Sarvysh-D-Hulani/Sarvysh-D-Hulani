---
import { Icon } from 'astro-icon/components';
import Image from '~/components/common/Image.astro';
import DocumentPreviewModal from '~/components/widgets/DocumentPreviewModal.astro';

export interface ProjectItem {
  title: string;
  excerpt?: string;
  coverImage?: string;
  tags?: string[];
  technologies?: string[];
  status?: string;
  slug?: string;
  attachedFile?: string;
  outcome?: string;
}

export interface Props {
  projects?: ProjectItem[];
  title?: string;
  subtitle?: string;
  tagline?: string;
  sectionNumber?: string;
  viewAllText?: string;
  viewAllHref?: string;
}

const {
  projects = [],
  title = 'Featured Projects',
  subtitle = 'Things I am building right now. Each project is a step toward becoming the engineer I want to be.',
  tagline = 'Projects',
  sectionNumber = '01',
  viewAllText = 'View All Projects',
  viewAllHref = '/projects',
} = Astro.props;

const statusColors: Record<string, string> = {
  'In Progress': 'bg-sapphire/10 text-sapphire border-sapphire/20',
  Shipped: 'bg-emerald2/10 text-emerald2 border-emerald2/20',
  Archived: 'bg-slate-400/10 text-slate-500 border-slate-400/20',
};
---

<section class="relative py-20 md:py-28 bg-page dark:bg-midnight overflow-hidden">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Section header with number badge -->
    <div
      class="flex flex-col items-center text-center mb-14 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
    >
      <div class="flex items-center gap-3 mb-4">
        <span class="text-5xl md:text-6xl font-bold tracking-tighter gradient-text opacity-20 select-none"
          >{sectionNumber}</span
        >
        <span class="h-px w-12 bg-gradient-to-r from-sapphire to-cyan2"></span>
        <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text">{tagline}</p>
      </div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter text-heading mb-4">{title}</h2>
      <p class="text-lg text-muted max-w-2xl mx-auto">{subtitle}</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-7">
      {
        projects.map((project, index) => (
          <div
            class="premium-card card-glow rounded-2xl overflow-hidden group flex flex-col intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade hover:border-sapphire/40 dark:hover:border-cyan2/30 hover:shadow-[0_8px_40px_rgb(15_76_160/0.18)]"
            style={`animation-delay: ${index * 100}ms;`}
          >
            {/* Clickable image + content area */}
            <a href={project.slug ? `/projects/${project.slug}` : '#'} class="block">
              {/* Cover image with 16:9 ratio */}
              {project.coverImage && (
                <div class="relative aspect-[16/9] overflow-hidden">
                  <Image
                    src={project.coverImage}
                    alt={project.title}
                    layout="cover"
                    class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
                  />
                  {/* Gradient overlay on hover */}
                  <div class="absolute inset-0 bg-gradient-to-t from-midnight/80 via-midnight/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
                  {project.status && (
                    <div
                      class={`absolute top-3 right-3 px-3 py-1 rounded-full text-xs font-semibold border backdrop-blur-sm ${statusColors[project.status] || statusColors['In Progress']}`}
                    >
                      {project.status}
                    </div>
                  )}
                </div>
              )}

              {/* Content */}
              <div class="p-5 md:p-6 pb-3">
                <h3 class="text-xl font-bold text-heading mb-2 group-hover:text-sapphire transition-colors duration-300">
                  {project.title}
                </h3>
                {project.excerpt && (
                  <p class="text-sm text-muted leading-relaxed mb-3 line-clamp-2">{project.excerpt}</p>
                )}

                {/* Outcome metric line */}
                {project.outcome && (
                  <p class="text-xs font-bold text-emerald2 mb-4 flex items-start gap-1.5 leading-snug">
                    <span class="text-emerald2 mt-0.5 shrink-0">&#9650;</span>
                    {project.outcome}
                  </p>
                )}

                {/* Technologies as gradient pills */}
                {project.technologies && project.technologies.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mb-4">
                    {project.technologies.slice(0, 4).map((tech) => (
                      <span class="px-2.5 py-1 rounded-full text-xs font-medium text-white bg-gradient-to-r from-sapphire to-cyan2 shadow-sm">
                        {tech}
                      </span>
                    ))}
                  </div>
                )}

                {/* Tags */}
                {project.tags && project.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {project.tags.map((tag) => (
                      <span class="text-xs text-muted">#{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>

            {/* Footer row — Read more + optional Preview button */}
            <div class="px-5 md:px-6 pb-5 mt-auto flex items-center justify-between gap-3">
              <a
                href={project.slug ? `/projects/${project.slug}` : '#'}
                class="flex items-center gap-1 text-sapphire dark:text-cyan2 text-sm font-semibold hover:gap-2 transition-all duration-300"
              >
                Read more
                <Icon
                  name="tabler:arrow-right"
                  class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1.5"
                />
              </a>

              {project.attachedFile && (
                <button
                  type="button"
                  data-preview-url={project.attachedFile}
                  data-preview-name={`${project.title} — Document`}
                  class="doc-preview-btn inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full text-xs font-semibold border border-sapphire/25 text-sapphire dark:text-cyan2 hover:bg-sapphire/10 dark:hover:bg-cyan2/10 hover:border-sapphire/50 transition-all duration-200 cursor-pointer shrink-0"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-3.5 h-3.5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14 2 14 8 20 8" />
                    <line x1="16" y1="13" x2="8" y2="13" />
                    <line x1="16" y1="17" x2="8" y2="17" />
                    <polyline points="10 9 9 9 8 9" />
                  </svg>
                  Preview
                </button>
              )}
            </div>
          </div>
        ))
      }
    </div>

    <!-- View All button with arrow animation -->
    <div class="text-center mt-12">
      <a
        href={viewAllHref}
        class="group inline-flex items-center gap-2 px-7 py-3.5 rounded-full border-2 border-sapphire/20 hover:border-sapphire/40 text-sapphire dark:text-cyan2 font-semibold transition-all duration-300 hover:shadow-lg hover:shadow-sapphire/10 hover:-translate-y-0.5"
      >
        {viewAllText}
        <Icon name="tabler:arrow-right" class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1.5" />
      </a>
    </div>
  </div>
</section>

<!-- Modal is rendered once per page; safe to include inside the component -->
<DocumentPreviewModal />

<script>
  // Wire all Preview buttons to open the DocumentPreviewModal
  document.querySelectorAll<HTMLButtonElement>('.doc-preview-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const fileUrl = btn.dataset.previewUrl ?? '';
      const fileName = btn.dataset.previewName ?? 'Document';
      window.dispatchEvent(new CustomEvent('open-doc-preview', { detail: { fileUrl, fileName } }));
    });
  });
</script>
