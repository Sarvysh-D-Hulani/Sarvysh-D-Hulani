---
import { Icon } from 'astro-icon/components';

export interface KnowledgeItem {
  title: string;
  excerpt?: string;
  category?: string;
  tags?: string[];
  difficulty?: string;
  slug?: string;
  publishDate?: Date;
}

export interface Props {
  items?: KnowledgeItem[];
  title?: string;
  subtitle?: string;
  tagline?: string;
  limit?: number;
}

const {
  items = [],
  title = 'Knowledge Hub',
  subtitle = 'A searchable collection of everything I learn. Notes, research, and insights organized by topic.',
  tagline = 'Knowledge',
  limit = 6,
} = Astro.props;

const limitedItems = items.slice(0, limit);

const categoryColors: Record<string, string> = {
  AI: 'from-sapphire to-cyan2',
  Engineering: 'from-navy to-sapphire',
  Finance: 'from-emerald2 to-cyan2',
  Consulting: 'from-gold to-amber-400',
  Productivity: 'from-cyan2 to-sapphire',
  Career: 'from-sapphire to-gold',
};

const categoryAccent: Record<string, string> = {
  AI: 'bg-sapphire',
  Engineering: 'bg-navy',
  Finance: 'bg-emerald2',
  Consulting: 'bg-gold',
  Productivity: 'bg-cyan2',
  Career: 'bg-sapphire',
};

const difficultyColors: Record<string, string> = {
  Beginner: 'bg-emerald2/10 text-emerald2',
  Intermediate: 'bg-sapphire/10 text-sapphire',
  Advanced: 'bg-gold/10 text-gold',
};
---

<section class="relative py-20 md:py-28 bg-page dark:bg-midnight overflow-hidden">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Section header with number badge -->
    <div class="flex flex-col items-center text-center mb-14 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-5xl md:text-6xl font-bold tracking-tighter gradient-text opacity-20 select-none">05</span>
        <span class="h-px w-12 bg-gradient-to-r from-sapphire to-cyan2"></span>
        <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text">{tagline}</p>
      </div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter text-heading mb-4">{title}</h2>
      <p class="text-lg text-muted max-w-2xl mx-auto">{subtitle}</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
      {limitedItems.map((item, index) => (
        <a
          href={item.slug ? `/knowledge-hub/${item.slug}` : '#'}
          class="premium-card card-glow rounded-2xl group block overflow-hidden intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
          style={`animation-delay: ${index * 80}ms;`}
        >
          <!-- Top accent bar in category color -->
          {item.category && (
            <div class={`h-1 ${categoryAccent[item.category] || 'bg-sapphire'}`}></div>
          )}

          <div class="p-6">
            <div class="flex items-center justify-between mb-4">
              {item.category && (
                <div class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold text-white bg-gradient-to-r ${categoryColors[item.category] || 'from-navy to-sapphire'} shadow-sm`}>
                  <Icon name="tabler:tag" class="w-3 h-3" />
                  {item.category}
                </div>
              )}
              {item.difficulty && (
                <span class={`px-2.5 py-0.5 rounded-full text-xs font-medium ${difficultyColors[item.difficulty] || difficultyColors.Beginner}`}>
                  {item.difficulty}
                </span>
              )}
            </div>

            <h3 class="text-lg font-bold text-heading mb-2 group-hover:text-sapphire transition-colors duration-300">
              {item.title}
            </h3>
            {item.excerpt && <p class="text-sm text-muted leading-relaxed mb-4 line-clamp-3">{item.excerpt}</p>}

            {item.tags && item.tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5">
                {item.tags.slice(0, 3).map((tag) => (
                  <span class="text-xs text-muted">#{tag}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-12">
      <a
        href="/knowledge-hub"
        class="group inline-flex items-center gap-2 px-7 py-3.5 rounded-full border-2 border-sapphire/20 hover:border-sapphire/40 text-sapphire dark:text-cyan2 font-semibold transition-all duration-300 hover:shadow-lg hover:shadow-sapphire/10 hover:-translate-y-0.5"
      >
        <Icon name="tabler:bolt" class="w-4 h-4" />
        Explore Knowledge Hub
        <Icon name="tabler:arrow-right" class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1.5" />
      </a>
    </div>
  </div>
</section>
