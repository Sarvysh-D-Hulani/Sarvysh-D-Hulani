---
/**
 * ProjectAttachments — compact inline row of attachment buttons for a project.
 *
 * Attachment types:
 *  - github  → external link, opens in new tab
 *  - demo    → external link, opens in new tab
 *  - pdf     → "View Document" triggers DocumentPreviewModal; separate Download link
 *  - xlsx    → "View Document" triggers DocumentPreviewModal; separate Download link
 *  - docx    → "View Document" triggers DocumentPreviewModal; separate Download link
 *  - pptx    → "View Document" via Office Online embed; separate Download link
 *
 * Also handles legacy `attachedFile` (single string) gracefully.
 */

export interface Attachment {
  type: 'github' | 'demo' | 'pdf' | 'xlsx' | 'docx' | 'pptx';
  url: string;
  label?: string;
}

export interface Props {
  attachments?: Attachment[];
  /** Legacy single-file field — treated as a generic document attachment */
  attachedFile?: string;
  projectTitle?: string;
  /** 'card' = compact inline row; 'detail' = slightly larger, more spacious */
  variant?: 'card' | 'detail';
}

const {
  attachments = [],
  attachedFile,
  projectTitle = 'Document',
  variant = 'card',
} = Astro.props;

// Merge legacy attachedFile into the list if not already covered by attachments
const allAttachments: Attachment[] = [...attachments];
if (attachedFile && !allAttachments.some((a) => a.url === attachedFile)) {
  // Infer type from extension
  const ext = attachedFile.split('?')[0].split('.').pop()?.toLowerCase() ?? '';
  const inferredType = (['pdf', 'xlsx', 'docx', 'pptx'] as const).includes(ext as never)
    ? (ext as 'pdf' | 'xlsx' | 'docx' | 'pptx')
    : 'pdf';
  allAttachments.push({ type: inferredType, url: attachedFile });
}

if (allAttachments.length === 0) return;

const isDetail = variant === 'detail';

// ── Label helpers ────────────────────────────────────────────────────────────
function defaultLabel(type: Attachment['type']): string {
  if (type === 'github') return 'View Code';
  if (type === 'demo') return 'Live Demo';
  return 'View Document';
}

// ── Icon SVGs (inline, no dependency) ───────────────────────────────────────
const githubIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>`;
const demoIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>`;
const docIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`;
const downloadIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`;

function iconFor(type: Attachment['type']): string {
  if (type === 'github') return githubIcon;
  if (type === 'demo') return demoIcon;
  return docIcon;
}

// Determine if an attachment needs a modal (pdf/xlsx/docx/pptx)
function needsModal(type: Attachment['type']): boolean {
  return type === 'pdf' || type === 'xlsx' || type === 'docx' || type === 'pptx';
}

const baseBtn = isDetail
  ? 'inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-semibold border transition-all duration-200'
  : 'inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold border transition-all duration-200';

const primaryBtn = `${baseBtn} border-sapphire/25 text-sapphire dark:text-cyan2 hover:bg-sapphire/10 dark:hover:bg-cyan2/10 hover:border-sapphire/50 cursor-pointer`;
const downloadBtn = isDetail
  ? 'inline-flex items-center gap-1 px-2.5 py-2 rounded-full text-sm border border-transparent text-muted hover:text-sapphire dark:hover:text-cyan2 hover:border-sapphire/20 transition-all duration-200'
  : 'inline-flex items-center gap-1 px-2 py-1.5 rounded-full text-xs border border-transparent text-muted hover:text-sapphire dark:hover:text-cyan2 hover:border-sapphire/20 transition-all duration-200';
---

<div class={`flex flex-wrap items-center gap-2 ${isDetail ? 'mt-2' : ''}`}>
  {
    allAttachments.map((att) => {
      const label = att.label || defaultLabel(att.type);
      const icon = iconFor(att.type);

      if (!needsModal(att.type)) {
        // External link — github / demo
        return (
          <a
            href={att.url}
            target="_blank"
            rel="noopener noreferrer"
            class={primaryBtn}
          >
            <Fragment set:html={icon} />
            {label}
          </a>
        );
      }

      // Document type — View button + Download link
      return (
        <span class="inline-flex items-center gap-0.5">
          <button
            type="button"
            data-preview-url={att.url}
            data-preview-name={`${projectTitle} — ${label}`}
            class={`doc-preview-btn ${primaryBtn}`}
          >
            <Fragment set:html={icon} />
            {label}
          </button>
          <a
            href={att.url}
            download
            title="Download file"
            class={downloadBtn}
          >
            <Fragment set:html={downloadIcon} />
            <span class="sr-only">Download {label}</span>
          </a>
        </span>
      );
    })
  }
</div>
