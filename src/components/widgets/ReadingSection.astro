---
import { Icon } from 'astro-icon/components';
import Image from '~/components/common/Image.astro';

export interface ReadingItem {
  title: string;
  author?: string;
  status?: string;
  rating?: number;
  coverImage?: string;
  notes?: string;
  quotes?: string[];
  category?: string;
  slug?: string;
}

export interface Props {
  items?: ReadingItem[];
  title?: string;
  subtitle?: string;
  tagline?: string;
  limit?: number;
}

const {
  items = [],
  title = 'Reading',
  subtitle = 'Books that shaped my thinking. Notes, quotes, and ratings included.',
  tagline = 'Reading',
  limit = 4,
} = Astro.props;

const limitedItems = items.slice(0, limit);

const statusConfig: Record<string, { label: string; color: string }> = {
  'Currently Reading': { label: 'Reading', color: 'bg-gradient-to-r from-sapphire to-cyan2 text-white' },
  Finished: { label: 'Finished', color: 'bg-gradient-to-r from-emerald2 to-cyan2 text-white' },
  'Want to Read': { label: 'Want to Read', color: 'bg-gradient-to-r from-gold to-amber-400 text-midnight' },
};
---

<section class="relative py-20 md:py-28 bg-section-alt overflow-hidden">
  <div
    class="absolute top-0 left-1/4 w-[400px] h-[300px] rounded-full bg-sapphire/5 blur-[120px] pointer-events-none"
    aria-hidden="true"
  >
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Section header with number badge -->
    <div
      class="flex flex-col items-center text-center mb-14 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
    >
      <div class="flex items-center gap-3 mb-4">
        <span class="text-5xl md:text-6xl font-bold tracking-tighter gradient-text opacity-20 select-none">07</span>
        <span class="h-px w-12 bg-gradient-to-r from-sapphire to-cyan2"></span>
        <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text">{tagline}</p>
      </div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter text-heading mb-4">{title}</h2>
      <p class="text-lg text-muted max-w-2xl mx-auto">{subtitle}</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 md:gap-6">
      {
        limitedItems.map((item, index) => {
          const status = statusConfig[item.status || 'Want to Read'] || statusConfig['Want to Read'];
          return (
            <div
              class="premium-card card-glow rounded-2xl overflow-hidden group intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
              style={`animation-delay: ${index * 80}ms;`}
            >
              {item.coverImage && (
                <div class="relative h-52 overflow-hidden">
                  <Image
                    src={item.coverImage}
                    alt={item.title}
                    layout="cover"
                    class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-midnight/60 to-transparent" />
                  <div class="absolute top-2 right-2">
                    <span class={`px-2.5 py-0.5 rounded-full text-xs font-bold shadow-sm ${status.color}`}>
                      {status.label}
                    </span>
                  </div>
                </div>
              )}
              <div class="p-5">
                <h3 class="text-base font-bold text-heading mb-1 line-clamp-2 group-hover:text-sapphire transition-colors duration-300">
                  {item.title}
                </h3>
                {item.author && <p class="text-sm text-muted mb-3 italic">{item.author}</p>}

                {item.rating && (
                  <div class="flex items-center gap-0.5 mb-3">
                    {Array.from({ length: 5 }).map((_, i) => (
                      <Icon
                        name={i < item.rating! ? 'tabler:star-filled' : 'tabler:star'}
                        class={`w-4 h-4 ${i < item.rating! ? 'text-gold' : 'text-slate-300 dark:text-slate-600'}`}
                      />
                    ))}
                  </div>
                )}

                {item.notes && <p class="text-xs text-muted leading-relaxed line-clamp-3 mb-3">{item.notes}</p>}

                {item.quotes && item.quotes.length > 0 && (
                  <div class="border-l-2 border-gold pl-3 mb-3">
                    <p class="text-xs italic text-muted leading-relaxed">"{item.quotes[0]}"</p>
                  </div>
                )}
              </div>
            </div>
          );
        })
      }
    </div>

    <div class="text-center mt-12">
      <a
        href="/reading"
        class="group inline-flex items-center gap-2 px-7 py-3.5 rounded-full border-2 border-sapphire/20 hover:border-sapphire/40 text-sapphire dark:text-cyan2 font-semibold transition-all duration-300 hover:shadow-lg hover:shadow-sapphire/10 hover:-translate-y-0.5"
      >
        <Icon name="tabler:book-2" class="w-4 h-4" />
        View All Books
        <Icon name="tabler:arrow-right" class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1.5" />
      </a>
    </div>
  </div>
</section>
