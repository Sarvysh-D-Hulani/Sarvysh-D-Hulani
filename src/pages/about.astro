---
import PageLayout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import { fetchPageContent } from '~/utils/collections';

const pageContent = await fetchPageContent('home');
const about = pageContent?.about || {};

const metadata = {
  title: 'About',
  description: about.story?.slice(0, 160) || 'My story, values, philosophy, and goals.',
};
---

<PageLayout metadata={metadata}>
  <!-- Hero header -->
  <section class="relative pt-20 md:pt-28 pb-16 md:pb-20 bg-gradient-to-b from-section-alt to-page dark:from-midnight dark:to-midnight overflow-hidden">
    <div class="absolute top-0 left-1/4 w-[400px] h-[300px] rounded-full bg-sapphire/5 blur-[120px] pointer-events-none" aria-hidden="true"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text mb-4 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">About</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter text-heading mb-6 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">My Story</h1>
      {about.story && <p class="text-lg lg:text-xl text-muted leading-relaxed max-w-3xl mx-auto intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">{about.story}</p>}
    </div>
  </section>

  {about.values && about.values.length > 0 && (
    <section class="py-16 md:py-24 bg-page dark:bg-midnight">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex flex-col items-center text-center mb-14 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text mb-3">Values</p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tighter text-heading mb-4">The Principles I Live By</h2>
          <p class="text-lg text-muted max-w-2xl mx-auto">The principles that guide every decision I make.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {about.values.map((value, index) => (
            <div class="premium-card card-glow rounded-2xl p-6 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade" style={`animation-delay: ${index * 80}ms;`}>
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-sapphire/10 to-cyan2/10 flex items-center justify-center mb-4">
                <Icon name="tabler:star" class="w-6 h-6 text-gold" />
              </div>
              <h3 class="text-base font-bold text-heading mb-2">{value.title}</h3>
              <p class="text-sm text-muted leading-relaxed">{value.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {about.philosophy && (
    <section class="py-16 md:py-24 bg-section-alt dark:bg-midnight">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
        <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text mb-3">Philosophy</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tighter text-heading mb-8">Philosophy</h2>
        <div class="relative">
          <div class="absolute -top-6 -left-2 text-7xl font-serif text-gold/20 select-none leading-none">"</div>
          <blockquote class="relative text-xl md:text-2xl text-heading leading-relaxed font-serif italic border-l-2 border-gold/50 pl-6 text-left">
            {about.philosophy}
          </blockquote>
          <div class="absolute -bottom-10 -right-2 text-7xl font-serif text-gold/20 select-none leading-none">"</div>
        </div>
      </div>
    </section>
  )}

  {about.interests && about.interests.length > 0 && (
    <section class="py-16 md:py-24 bg-page dark:bg-midnight">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="flex flex-col items-center text-center mb-10 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text mb-3">Interests</p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tighter text-heading mb-4">Interests</h2>
        </div>
        <div class="flex flex-wrap justify-center gap-3 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          {about.interests.map((interest) => (
            <span class="px-4 py-2 rounded-full text-sm font-medium bg-gradient-to-r from-sapphire/10 to-cyan2/10 text-sapphire dark:text-cyan2 border border-sapphire/10 dark:border-cyan2/10">{interest}</span>
          ))}
        </div>
      </div>
    </section>
  )}

  {about.goals && about.goals.length > 0 && (
    <section class="py-16 md:py-24 bg-section-alt dark:bg-midnight">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="flex flex-col items-center text-center mb-10 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text mb-3">Goals</p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tighter text-heading mb-4">Goals</h2>
        </div>
        <div class="space-y-4">
          {about.goals.map((goal, index) => (
            <div class="flex items-start gap-3 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade" style={`animation-delay: ${index * 60}ms;`}>
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-gradient-to-br from-sapphire to-cyan2 flex items-center justify-center mt-0.5">
                <Icon name="tabler:check" class="w-4 h-4 text-white" />
              </div>
              <p class="text-base text-heading">{goal}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {about.learning && about.learning.length > 0 && (
    <section class="py-16 md:py-24 bg-page dark:bg-midnight">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="flex flex-col items-center text-center mb-10 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text mb-3">Learning</p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tighter text-heading mb-4">Things I'm Learning</h2>
        </div>
        <div class="grid sm:grid-cols-2 gap-3">
          {about.learning.map((item, index) => (
            <div class="flex items-center gap-3 p-4 rounded-xl bg-gradient-to-r from-sapphire/5 to-cyan2/5 border border-sapphire/10 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade" style={`animation-delay: ${index * 60}ms;`}>
              <Icon name="tabler:book-2" class="w-5 h-5 text-sapphire dark:text-cyan2 flex-shrink-0" />
              <span class="text-sm text-heading">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {about.beliefs && about.beliefs.length > 0 && (
    <section class="py-16 md:py-24 bg-section-alt dark:bg-midnight">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="flex flex-col items-center text-center mb-10 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text mb-3">Beliefs</p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tighter text-heading mb-4">Things I Believe</h2>
        </div>
        <div class="space-y-5">
          {about.beliefs.map((belief, index) => (
            <blockquote class="text-lg text-heading italic border-l-2 border-gold/50 pl-5 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade" style={`animation-delay: ${index * 80}ms;`}>
              {belief}
            </blockquote>
          ))}
        </div>
      </div>
    </section>
  )}

  {about.faq && about.faq.length > 0 && (
    <section class="py-16 md:py-24 bg-page dark:bg-midnight">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="flex flex-col items-center text-center mb-10 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text mb-3">FAQ</p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tighter text-heading mb-4">Frequently Asked Questions</h2>
        </div>
        <div class="space-y-4">
          {about.faq.map((item, index) => (
            <details class="premium-card-flat rounded-2xl p-5 group intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade" style={`animation-delay: ${index * 80}ms;`}>
              <summary class="text-base font-semibold text-heading cursor-pointer flex items-center justify-between list-none">
                {item.question}
                <Icon name="tabler:chevron-down" class="w-5 h-5 text-muted transition-transform duration-300 group-open:rotate-180" />
              </summary>
              <p class="mt-3 text-sm text-muted leading-relaxed">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}
</PageLayout>
