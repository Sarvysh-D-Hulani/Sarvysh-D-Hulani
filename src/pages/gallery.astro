---
import PageLayout from '~/layouts/PageLayout.astro';
import Image from '~/components/common/Image.astro';
import { fetchGallery } from '~/utils/collections';

const items = await fetchGallery();
const albums = [...new Set(items.map((i) => i.album).filter(Boolean))];

const metadata = {
  title: 'Gallery',
  description: 'Moments from campus, travels, and the everyday life.',
};
---

<PageLayout metadata={metadata}>
  <!-- Hero header -->
  <section class="relative pt-20 md:pt-28 pb-16 md:pb-20 bg-gradient-to-b from-section-alt to-page dark:from-midnight dark:to-midnight overflow-hidden">
    <div class="absolute top-0 left-1/4 w-[400px] h-[300px] rounded-full bg-sapphire/5 blur-[120px] pointer-events-none" aria-hidden="true"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text mb-4 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">Gallery</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter text-heading mb-6 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">Gallery</h1>
      <p class="text-lg lg:text-xl text-muted leading-relaxed max-w-2xl mx-auto intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">Moments from campus, travels, and the everyday life that makes the journey real.</p>
    </div>
  </section>

  <section class="pb-20 bg-page dark:bg-midnight">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      {albums.length > 0 && (
        <div class="flex flex-wrap justify-center gap-2 mb-10 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <button class="px-5 py-2.5 rounded-full text-sm font-medium bg-gradient-to-r from-sapphire to-cyan2 text-white shadow-sm transition-all" data-filter="all">All</button>
          {albums.map((album) => (
            <button class="px-5 py-2.5 rounded-full text-sm font-medium bg-navy/5 dark:bg-sapphire/10 text-sapphire dark:text-cyan2 hover:bg-navy/10 hover:shadow-md transition-all" data-filter={album}>{album}</button>
          ))}
        </div>
      )}

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4" id="gallery-grid">
        {items.map((item, index) => (
          <div
            class={`group relative rounded-2xl overflow-hidden cursor-pointer intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-scale-in ${index === 0 ? 'col-span-2 row-span-2 md:col-span-2 md:row-span-2' : ''}`}
            style={`animation-delay: ${index * 60}ms;`}
            data-album={item.album || ''}
          >
            <Image
              src={item.image}
              alt={item.title}
              layout="responsive"
              class={`w-full ${index === 0 ? 'h-full min-h-[300px] md:min-h-[400px]' : 'h-40 md:h-48'} object-cover transition-transform duration-700 ease-out group-hover:scale-125`}
            />
            <!-- Dramatic gradient overlay on hover -->
            <div class="absolute inset-0 bg-gradient-to-t from-midnight/90 via-midnight/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="absolute inset-0 ring-2 ring-sapphire/0 group-hover:ring-sapphire/40 rounded-2xl transition-all duration-400"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-500">
              <p class="text-sm font-bold text-ivory">{item.title}</p>
              {item.caption && <p class="text-xs text-ivory/70 mt-0.5">{item.caption}</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<script is:inline>
  document.querySelectorAll('[data-filter]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');
      document.querySelectorAll('[data-filter]').forEach((b) => {
        b.classList.remove('bg-gradient-to-r', 'from-sapphire', 'to-cyan2', 'text-white', 'shadow-sm');
        b.classList.add('bg-navy/5', 'dark:bg-sapphire/10', 'text-sapphire', 'dark:text-cyan2');
      });
      btn.classList.add('bg-gradient-to-r', 'from-sapphire', 'to-cyan2', 'text-white', 'shadow-sm');
      btn.classList.remove('bg-navy/5', 'dark:bg-sapphire/10', 'text-sapphire', 'dark:text-cyan2');
      document.querySelectorAll('#gallery-grid > [data-album]').forEach((card) => {
        if (filter === 'all' || card.getAttribute('data-album') === filter) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
