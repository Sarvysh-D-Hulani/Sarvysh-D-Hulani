---
import PageLayout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import CredentialsStrip from '~/components/widgets/CredentialsStrip.astro';
import NowSection from '~/components/widgets/NowSection.astro';
import FeaturedProjects from '~/components/widgets/FeaturedProjects.astro';
import KnowledgeHub from '~/components/widgets/KnowledgeHub.astro';
import ResourceLibrary from '~/components/widgets/ResourceLibrary.astro';
import GallerySection from '~/components/widgets/GallerySection.astro';
import ReadingSection from '~/components/widgets/ReadingSection.astro';
import AboutPreview from '~/components/widgets/AboutPreview.astro';
import ContactSection from '~/components/widgets/ContactSection.astro';

import {
  fetchPageContent,
  fetchFeaturedProjects,
  fetchKnowledge,
  fetchResources,
  fetchGallery,
  fetchReading,
} from '~/utils/collections';

const pageContent = await fetchPageContent('home');
const featuredProjects = await fetchFeaturedProjects();
const knowledgeItems = await fetchKnowledge();
const resourceItems = await fetchResources();
const galleryItems = await fetchGallery();
const readingItems = await fetchReading();

const hero = pageContent?.hero || {};
const now = pageContent?.now || {};
const about = pageContent?.about || {};
const contact = pageContent?.contact || {};
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const credentials = (pageContent as Record<string, any>)?.credentials || {};
const exploreDivider = pageContent?.exploreDivider || {};
const sections = pageContent?.sections || [];

/* eslint-disable @typescript-eslint/no-explicit-any */
const getSectionData = (id: string): Record<string, any> =>
  (sections as Record<string, any>[]).find((s: Record<string, any>) => s.id === id) || {};

const isVisible = (id: string) =>
  !sections.length ||
  (sections as Record<string, any>[]).find((s: Record<string, any>) => s.id === id)?.visible !== false;
/* eslint-enable @typescript-eslint/no-explicit-any */

const metadata = {
  title: 'Digital HQ — The Evolving World of an Ambitious Student',
  description:
    'The digital headquarters of an ambitious BITS Pilani student growing into an AI engineer, consultant, investor, and creator.',
  ignoreTitleTemplate: true,
};
---

<PageLayout metadata={metadata}>
  {
    isVisible('hero') && (
      <Hero
        name={hero.name}
        tagline={hero.tagline}
        identity={hero.identity}
        currentFocus={hero.currentFocus}
        profileImage={hero.profileImage}
        actions={
          hero.actions as Array<{
            text: string;
            href: string;
            variant?: 'primary' | 'secondary' | 'tertiary' | 'link';
            icon?: string;
          }>
        }
        floatingCards={hero.floatingCards}
      />
    )
  }

  {/* Compact credentials strip directly below hero */}
  {credentials.stats && credentials.stats.length > 0 && <CredentialsStrip stats={credentials.stats} />}

  {/* Featured Projects moved up — immediately after credentials */}
  {
    isVisible('featured-projects') && featuredProjects.length > 0 && (
      <FeaturedProjects
        projects={featuredProjects}
        title={getSectionData('featured-projects').title}
        subtitle={getSectionData('featured-projects').subtitle}
        tagline={getSectionData('featured-projects').tagline}
        sectionNumber={getSectionData('featured-projects').sectionNumber}
        viewAllText={getSectionData('featured-projects').viewAllText}
        viewAllHref={getSectionData('featured-projects').viewAllHref}
      />
    )
  }

  {
    isVisible('now') && (
      <NowSection
        building={now.building}
        learning={now.learning}
        reading={now.reading}
        goal={now.goal}
        semester={now.semester}
        experiments={now.experiments}
        sectionNumber={getSectionData('now').sectionNumber}
        tagline={getSectionData('now').tagline}
        title={getSectionData('now').title}
        subtitle={getSectionData('now').subtitle}
        buildingLabel={now.buildingLabel}
        learningLabel={now.learningLabel}
        readingLabel={now.readingLabel}
        goalLabel={now.goalLabel}
        semesterLabel={now.semesterLabel}
        experimentsLabel={now.experimentsLabel}
      />
    )
  }

  {
    isVisible('about-preview') && (
      <AboutPreview
        name={hero.name}
        story={(() => {
          // Show only the pull-quote (first paragraph) from the full story
          const firstPara = (about.story || '').split(/\n\n+/)[0]?.trim() || about.story;
          return firstPara;
        })()}
        values={about.values}
        interests={about.interests}
      />
    )
  }

  {/* ── Journey link (replaces full Journey Timeline section) ── */}
  <div class="py-6 flex justify-center bg-page dark:bg-midnight">
    <p class="text-sm text-muted text-center px-6">
      A few years, a few failures, a lot of lessons —{' '}
      <a href="/journey" class="font-semibold text-sapphire dark:text-cyan2 hover:underline underline-offset-4 transition-colors">
        see the full journey
      </a>
      .
    </p>
  </div>

  {/* ── Explore More — gateway link row ── */}
  <div class="relative py-12 md:py-16 flex flex-col items-center gap-6 bg-page dark:bg-midnight">
    <div class="flex items-center gap-4 w-full max-w-2xl px-6">
      <div class="flex-1 h-px bg-gradient-to-r from-transparent via-sapphire/30 to-transparent"></div>
      <span class="px-5 py-2 rounded-full border border-sapphire/20 bg-sapphire/5 text-xs font-bold tracking-[0.2em] uppercase text-sapphire dark:text-cyan2">
        Explore More
      </span>
      <div class="flex-1 h-px bg-gradient-to-r from-transparent via-cyan2/30 to-transparent"></div>
    </div>
    <div class="flex flex-wrap justify-center gap-3 px-6">
      <a
        href="/journey"
        class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full border border-sapphire/20 hover:border-sapphire/40 text-sm font-semibold text-sapphire dark:text-cyan2 hover:bg-sapphire/5 transition-all duration-200"
      >
        Journey
      </a>
      <a
        href="/writing"
        class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full border border-sapphire/20 hover:border-sapphire/40 text-sm font-semibold text-sapphire dark:text-cyan2 hover:bg-sapphire/5 transition-all duration-200"
      >
        Writing
      </a>
      <a
        href="/knowledge-hub"
        class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full border border-sapphire/20 hover:border-sapphire/40 text-sm font-semibold text-sapphire dark:text-cyan2 hover:bg-sapphire/5 transition-all duration-200"
      >
        Knowledge Hub
      </a>
      <a
        href="/gallery"
        class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full border border-sapphire/20 hover:border-sapphire/40 text-sm font-semibold text-sapphire dark:text-cyan2 hover:bg-sapphire/5 transition-all duration-200"
      >
        Gallery
      </a>
    </div>
  </div>

  {isVisible('knowledge-hub') && knowledgeItems.length > 0 && <KnowledgeHub items={knowledgeItems} limit={2} />}

  {isVisible('resource-library') && resourceItems.length > 0 && <ResourceLibrary items={resourceItems} limit={2} />}

  {isVisible('gallery') && galleryItems.length > 0 && <GallerySection items={galleryItems} limit={3} />}

  {isVisible('reading') && readingItems.length > 0 && <ReadingSection items={readingItems} limit={2} />}

  {
    isVisible('contact') && (
      <ContactSection
        title={contact.title}
        subtitle={contact.subtitle}
        email={contact.email}
        socials={contact.socials}
      />
    )
  }
</PageLayout>
