---
import PageLayout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import CredentialsStrip from '~/components/widgets/CredentialsStrip.astro';
import NowSection from '~/components/widgets/NowSection.astro';
import FeaturedProjects from '~/components/widgets/FeaturedProjects.astro';
import JourneyTimeline from '~/components/widgets/JourneyTimeline.astro';
import KnowledgeHub from '~/components/widgets/KnowledgeHub.astro';
import ResourceLibrary from '~/components/widgets/ResourceLibrary.astro';
import GallerySection from '~/components/widgets/GallerySection.astro';
import ReadingSection from '~/components/widgets/ReadingSection.astro';
import AboutPreview from '~/components/widgets/AboutPreview.astro';
import ContactSection from '~/components/widgets/ContactSection.astro';

import {
  fetchPageContent,
  fetchFeaturedProjects,
  fetchJourney,
  fetchKnowledge,
  fetchResources,
  fetchGallery,
  fetchReading,
} from '~/utils/collections';
import { findLatestPosts } from '~/utils/blog';
import { APP_BLOG } from 'astrowind:config';

const pageContent = await fetchPageContent('home');
const featuredProjects = await fetchFeaturedProjects();
const journeyItems = await fetchJourney();
const knowledgeItems = await fetchKnowledge();
const resourceItems = await fetchResources();
const galleryItems = await fetchGallery();
const readingItems = await fetchReading();
const latestPosts = APP_BLOG.isEnabled ? await findLatestPosts({ count: 3 }) : [];

const hero = pageContent?.hero || {};
const now = pageContent?.now || {};
const about = pageContent?.about || {};
const contact = pageContent?.contact || {};
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const credentials = (pageContent as Record<string, any>)?.credentials || {};
const exploreDivider = pageContent?.exploreDivider || {};
const sections = pageContent?.sections || [];

/* eslint-disable @typescript-eslint/no-explicit-any */
const getSectionData = (id: string): Record<string, any> =>
  (sections as Record<string, any>[]).find((s: Record<string, any>) => s.id === id) || {};

const isVisible = (id: string) =>
  !sections.length ||
  (sections as Record<string, any>[]).find((s: Record<string, any>) => s.id === id)?.visible !== false;
/* eslint-enable @typescript-eslint/no-explicit-any */

const metadata = {
  title: 'Digital HQ — The Evolving World of an Ambitious Student',
  description:
    'The digital headquarters of an ambitious BITS Pilani student growing into an AI engineer, consultant, investor, and creator.',
  ignoreTitleTemplate: true,
};
---

<PageLayout metadata={metadata}>
  {
    isVisible('hero') && (
      <Hero
        name={hero.name}
        tagline={hero.tagline}
        identity={hero.identity}
        currentFocus={hero.currentFocus}
        profileImage={hero.profileImage}
        actions={
          hero.actions as Array<{
            text: string;
            href: string;
            variant?: 'primary' | 'secondary' | 'tertiary' | 'link';
            icon?: string;
          }>
        }
        floatingCards={hero.floatingCards}
      />
    )
  }

  {/* Compact credentials strip directly below hero */}
  {credentials.stats && credentials.stats.length > 0 && <CredentialsStrip stats={credentials.stats} />}

  {/* Featured Projects moved up — immediately after credentials */}
  {
    isVisible('featured-projects') && featuredProjects.length > 0 && (
      <FeaturedProjects
        projects={featuredProjects}
        title={getSectionData('featured-projects').title}
        subtitle={getSectionData('featured-projects').subtitle}
        tagline={getSectionData('featured-projects').tagline}
        sectionNumber={getSectionData('featured-projects').sectionNumber}
        viewAllText={getSectionData('featured-projects').viewAllText}
        viewAllHref={getSectionData('featured-projects').viewAllHref}
      />
    )
  }

  {
    isVisible('now') && (
      <NowSection
        building={now.building}
        learning={now.learning}
        reading={now.reading}
        goal={now.goal}
        semester={now.semester}
        experiments={now.experiments}
        sectionNumber={getSectionData('now').sectionNumber}
        tagline={getSectionData('now').tagline}
        title={getSectionData('now').title}
        subtitle={getSectionData('now').subtitle}
        buildingLabel={now.buildingLabel}
        learningLabel={now.learningLabel}
        readingLabel={now.readingLabel}
        goalLabel={now.goalLabel}
        semesterLabel={now.semesterLabel}
        experimentsLabel={now.experimentsLabel}
      />
    )
  }

  {/* ── Explore More divider ── */}
  <div class="relative py-12 md:py-16 flex flex-col items-center gap-4 bg-page dark:bg-midnight">
    <div class="flex items-center gap-4 w-full max-w-2xl px-6">
      <div class="flex-1 h-px bg-gradient-to-r from-transparent via-sapphire/30 to-transparent"></div>
      <span
        class="px-5 py-2 rounded-full border border-sapphire/20 bg-sapphire/5 text-xs font-bold tracking-[0.2em] uppercase text-sapphire dark:text-cyan2"
      >
        {exploreDivider.label || 'Explore More'}
      </span>
      <div class="flex-1 h-px bg-gradient-to-r from-transparent via-cyan2/30 to-transparent"></div>
    </div>
    <p class="text-sm text-muted text-center max-w-md px-6">
      {exploreDivider.description || "Journey, knowledge, gallery, writing and more — there's a lot going on. Dig in."}
    </p>
  </div>

  {isVisible('journey-timeline') && journeyItems.length > 0 && <JourneyTimeline items={journeyItems} limit={4} />}

  {isVisible('knowledge-hub') && knowledgeItems.length > 0 && <KnowledgeHub items={knowledgeItems} limit={6} />}

  {isVisible('resource-library') && resourceItems.length > 0 && <ResourceLibrary items={resourceItems} limit={4} />}

  {isVisible('gallery') && galleryItems.length > 0 && <GallerySection items={galleryItems} limit={6} />}

  {
    isVisible('latest-writing') && latestPosts.length > 0 && (
      <section class="relative py-16 md:py-24 bg-page dark:bg-midnight">
        <div class="max-w-7xl mx-auto px-4 sm:px-6">
          <div class="text-center mb-12 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
            <p class="text-sm font-bold tracking-widest uppercase gradient-text mb-3">Writing</p>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-heading mb-4">Latest Writing</h2>
            <p class="text-lg text-muted max-w-2xl mx-auto">Thoughts, reflections, and lessons from the journey.</p>
          </div>
          <div class="grid md:grid-cols-3 gap-6">
            {latestPosts.map((post, index) => (
              <a
                href={`/${post.permalink}`}
                class="premium-card overflow-hidden group block intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
                style={`animation-delay: ${index * 100}ms;`}
              >
                {post.image && (
                  <div class="h-40 overflow-hidden">
                    <img
                      src={typeof post.image === 'string' ? post.image : ''}
                      alt={post.title}
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    />
                  </div>
                )}
                <div class="p-5">
                  {post.category && (
                    <span class="text-xs font-semibold text-sapphire dark:text-cyan2 uppercase tracking-wider">
                      {post.category.title}
                    </span>
                  )}
                  <h3 class="text-lg font-bold text-heading mt-2 mb-2 group-hover:text-sapphire transition-colors">
                    {post.title}
                  </h3>
                  {post.excerpt && <p class="text-sm text-muted line-clamp-2">{post.excerpt}</p>}
                </div>
              </a>
            ))}
          </div>
          <div class="text-center mt-10">
            <a
              href="/writing"
              class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full btn-secondary font-semibold"
            >
              Read All Writing
            </a>
          </div>
        </div>
      </section>
    )
  }

  {isVisible('reading') && readingItems.length > 0 && <ReadingSection items={readingItems} limit={4} />}

  {
    isVisible('about-preview') && (
      <AboutPreview name={hero.name} story={about.story} values={about.values} interests={about.interests} />
    )
  }

  {
    isVisible('contact') && (
      <ContactSection
        title={contact.title}
        subtitle={contact.subtitle}
        email={contact.email}
        socials={contact.socials}
      />
    )
  }
</PageLayout>
