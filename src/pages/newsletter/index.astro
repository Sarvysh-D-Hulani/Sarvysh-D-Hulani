---
import PageLayout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import { fetchNewsletters } from '~/utils/collections';

const items = await fetchNewsletters();

const metadata = {
  title: 'Newsletter',
  description: 'Weekly notes on building, learning, and growing.',
};

const formatDate = (date: Date) => new Intl.DateTimeFormat('en', { month: 'long', day: 'numeric', year: 'numeric' }).format(date);
---

<PageLayout metadata={metadata}>
  <!-- Hero header with gradient-deep-sea -->
  <section class="relative pt-20 md:pt-28 pb-16 md:pb-20 gradient-deep-sea overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/3 w-[400px] h-[400px] rounded-full bg-sapphire/10 blur-[120px]"></div>
      <div class="absolute bottom-0 right-1/3 w-[300px] h-[300px] rounded-full bg-gold/5 blur-[100px]"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text-gold mb-4 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">Newsletter</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-ivory mb-6 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">Newsletter</h1>
      <p class="text-lg text-ivory/60 max-w-2xl mx-auto mb-8 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">Weekly notes on building, learning, and growing. No spam, just genuine updates.</p>
      <div class="max-w-md mx-auto intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-scale-in">
        <form class="flex flex-col sm:flex-row gap-3">
          <input type="email" placeholder="your@email.com" class="flex-1 px-4 py-3 rounded-full bg-ivory/10 border border-ivory/20 text-ivory placeholder-ivory/40 focus:outline-none focus:border-gold/50 focus:ring-2 focus:ring-gold/20 transition" />
          <button type="submit" class="px-6 py-3 rounded-full bg-gradient-to-r from-gold to-amber-400 text-midnight font-semibold hover:shadow-lg hover:shadow-gold/20 transition-all cursor-pointer whitespace-nowrap">Subscribe</button>
        </form>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-page dark:bg-midnight">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="flex items-center gap-3 mb-8 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
        <span class="h-px w-12 bg-gradient-to-r from-sapphire to-cyan2"></span>
        <h2 class="text-2xl font-bold tracking-tight text-heading">Archive</h2>
      </div>
      <div class="space-y-4">
        {items.map((item, index) => (
          <a href={`/newsletter/${item.slug}`} class="block premium-card-flat p-5 hover:border-sapphire/30 transition-all intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade" style={`animation-delay: ${index * 100}ms;`}>
            <div class="flex items-start justify-between gap-4">
              <div>
                <div class="flex items-center gap-2 mb-1">
                  {item.issue && <span class="text-xs font-semibold text-gold">Issue #{item.issue}</span>}
                  <span class="text-xs text-muted">{formatDate(item.publishDate)}</span>
                </div>
                <h3 class="text-base font-semibold text-heading mb-1">{item.title}</h3>
                {item.excerpt && <p class="text-sm text-muted line-clamp-2">{item.excerpt}</p>}
              </div>
              <Icon name="tabler:arrow-right" class="w-5 h-5 text-muted flex-shrink-0 mt-1" />
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
