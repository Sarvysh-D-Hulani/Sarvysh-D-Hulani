---
import PageLayout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import Image from '~/components/common/Image.astro';
import DocumentPreviewModal from '~/components/widgets/DocumentPreviewModal.astro';
import ProjectAttachments from '~/components/widgets/ProjectAttachments.astro';
import { fetchProjects } from '~/utils/collections';

export async function getStaticPaths() {
  const projects = await fetchProjects();
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { getCollection, render } = await import('astro:content');
const entries = await getCollection('project');
const entry = entries.find((e) => e.id.replace(/\.md$/, '').replace(/\.mdx$/, '') === project.slug);
const Content = entry ? (await render(entry)).Content : null;

const metadata = {
  title: project.title,
  description: project.excerpt || '',
};

const formatDate = (date?: Date) =>
  date ? new Intl.DateTimeFormat('en', { month: 'short', year: 'numeric' }).format(date) : '';

// Render a frontmatter markdown string to HTML (handles bullet lists, bold, etc.)
function mdToHtml(src: string | undefined): string {
  if (!src) return '';
  // Bold: **text** → <strong>text</strong>
  let html = src
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
  // Convert lines that start with "- " into a <ul><li> list
  const lines = html.split('\n');
  const out: string[] = [];
  let inList = false;
  for (const raw of lines) {
    const line = raw.trimEnd();
    if (/^[-*]\s+/.test(line)) {
      if (!inList) { out.push('<ul class="list-disc list-outside pl-5 space-y-1.5">'); inList = true; }
      out.push(`<li>${applyInline(line.replace(/^[-*]\s+/, ''))}</li>`);
    } else {
      if (inList) { out.push('</ul>'); inList = false; }
      if (line.trim() !== '') out.push(`<p>${applyInline(line)}</p>`);
    }
  }
  if (inList) out.push('</ul>');
  return out.join('\n');
}

function applyInline(s: string): string {
  return s
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/`(.+?)`/g, '<code>$1</code>');
}
---

<PageLayout metadata={metadata}>
  <!-- Hero header -->
  <section
    class="relative pt-20 md:pt-28 pb-12 md:pb-16 bg-gradient-to-b from-section-alt to-page dark:from-midnight dark:to-midnight overflow-hidden"
  >
    <div
      class="absolute top-0 left-1/4 w-[400px] h-[300px] rounded-full bg-sapphire/5 blur-[120px] pointer-events-none"
      aria-hidden="true"
    >
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6">
      <a
        href="/projects"
        class="inline-flex items-center gap-1.5 text-sm text-muted hover:text-sapphire dark:hover:text-cyan2 transition mb-8 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
      >
        <Icon name="tabler:arrow-left" class="w-4 h-4" />
        Back to Projects
      </a>
      <div
        class="flex items-center gap-3 mb-4 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
      >
        {
          project.status && (
            <span class="px-3 py-1 rounded-full text-xs font-semibold bg-sapphire/10 text-sapphire border border-sapphire/20">
              {project.status}
            </span>
          )
        }
        {
          project.startDate && (
            <span class="text-sm text-muted">
              {formatDate(project.startDate)} — {project.endDate ? formatDate(project.endDate) : 'Present'}
            </span>
          )
        }
      </div>
      <h1
        class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter text-heading mb-4 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
      >
        {project.title}
      </h1>
      {
        project.excerpt && (
          <p class="text-lg lg:text-xl text-muted leading-relaxed max-w-3xl intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
            {project.excerpt}
          </p>
        )
      }
    </div>
  </section>

  <article class="pb-20 bg-page dark:bg-midnight">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <!-- Cover image -->
      {
        project.coverImage && (
          <div class="rounded-2xl overflow-hidden mb-10 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-scale-in">
            <Image
              src={project.coverImage}
              alt={project.title}
              layout="responsive"
              class="w-full h-64 md:h-80 object-cover"
            />
          </div>
        )
      }

      <!-- Attachments row (github, demo, pdf, xlsx, docx, pptx) -->
      {
        (project.attachments?.length || project.github || project.demo || project.attachedFile) && (
          <div class="mb-10 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
            <ProjectAttachments
              attachments={[
                ...(project.github ? [{ type: 'github' as const, url: project.github }] : []),
                ...(project.demo ? [{ type: 'demo' as const, url: project.demo }] : []),
                ...(project.attachments ?? []),
              ]}
              attachedFile={project.attachedFile}
              projectTitle={project.title}
              variant="detail"
            />
          </div>
        )
      }

      <!-- Tech stack -->
      {
        project.technologies && project.technologies.length > 0 && (
          <div class="mb-10 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
            <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text mb-3">Tech Stack</p>
            <div class="flex flex-wrap gap-2">
              {project.technologies.map((tech) => (
                <span class="px-3 py-1.5 rounded-full text-sm font-medium text-white bg-gradient-to-r from-sapphire to-cyan2 shadow-sm">
                  {tech}
                </span>
              ))}
            </div>
          </div>
        )
      }

      <!-- Content sections -->
      <div class="space-y-6">
        {
          project.problem && (
            <div class="premium-card p-6 md:p-8 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
              <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text mb-3">The Problem</p>
              <div class="text-base text-muted leading-relaxed project-rich-field" set:html={mdToHtml(project.problem)} />
            </div>
          )
        }
        {
          project.whyBuilt && (
            <div class="premium-card p-6 md:p-8 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
              <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text mb-3">Why I Built It</p>
              <div class="text-base text-muted leading-relaxed project-rich-field" set:html={mdToHtml(project.whyBuilt)} />
            </div>
          )
        }
        {
          project.process && (
            <div class="premium-card p-6 md:p-8 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
              <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text mb-3">Process</p>
              <div class="text-base text-muted leading-relaxed project-rich-field" set:html={mdToHtml(project.process)} />
            </div>
          )
        }
        {
          project.challenges && (
            <div class="premium-card p-6 md:p-8 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
              <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text mb-3">Challenges</p>
              <div class="text-base text-muted leading-relaxed project-rich-field" set:html={mdToHtml(project.challenges)} />
            </div>
          )
        }
        {
          project.learnings && (
            <div class="premium-card p-6 md:p-8 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
              <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text mb-3">What I Learned</p>
              <div class="text-base text-muted leading-relaxed project-rich-field" set:html={mdToHtml(project.learnings)} />
            </div>
          )
        }
        {
          project.futureImprovements && (
            <div class="premium-card p-6 md:p-8 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
              <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text mb-3">Future Improvements</p>
              <div class="text-base text-muted leading-relaxed project-rich-field" set:html={mdToHtml(project.futureImprovements)} />
            </div>
          )
        }
      </div>

      <!-- Gallery -->
      {
        project.gallery && project.gallery.length > 0 && (
          <div class="mt-10 grid grid-cols-2 gap-4">
            {project.gallery.map((img) => (
              <div class="rounded-xl overflow-hidden">
                <Image src={img} alt={project.title} layout="responsive" class="w-full h-48 object-cover" />
              </div>
            ))}
          </div>
        )
      }

      <!-- Tags -->
      {
        project.tags && project.tags.length > 0 && (
          <div class="mt-10 flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class="px-3 py-1.5 rounded-full text-sm text-muted bg-navy/5 dark:bg-sapphire/5">#{tag}</span>
            ))}
          </div>
        )
      }

      <!-- Rendered markdown content if any -->
      {
        Content && (
          <div class="prose prose-lg dark:prose-invert max-w-none mt-10">
            <Content />
          </div>
        )
      }
    </div>
  </article>

  <DocumentPreviewModal />
</PageLayout>
