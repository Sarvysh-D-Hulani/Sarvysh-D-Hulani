---
import PageLayout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import { fetchResume } from '~/utils/collections';

const resume = await fetchResume();

const metadata = {
  title: 'Resume',
  description: resume?.subtitle || 'My education, experience, skills, and what I am looking for.',
};
---

<PageLayout metadata={metadata}>
  <!-- Hero -->
  <section class="relative pt-20 md:pt-28 pb-16 md:pb-20 gradient-deep-sea overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/3 w-[400px] h-[400px] rounded-full bg-sapphire/10 blur-[120px]"></div>
      <div class="absolute bottom-0 right-1/3 w-[300px] h-[300px] rounded-full bg-gold/5 blur-[100px]"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text-gold mb-4 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
        Resume
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-ivory mb-4 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
        {resume?.title || 'Resume'}
      </h1>
      {resume?.subtitle && (
        <p class="text-lg text-ivory/60 max-w-2xl mx-auto mb-8 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          {resume.subtitle}
        </p>
      )}
      <div class="flex flex-wrap items-center justify-center gap-3 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-gradient-to-r from-gold to-amber-400 text-midnight font-semibold hover:shadow-lg hover:shadow-gold/20 transition-all text-sm"
        >
          <Icon name="tabler:mail" class="w-4 h-4" />
          Get in Touch
        </a>
        <a
          href="/files/resume.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-ivory/20 text-ivory/80 hover:border-ivory/40 hover:text-ivory font-semibold transition-all text-sm"
        >
          <Icon name="tabler:download" class="w-4 h-4" />
          Download PDF
        </a>
      </div>
    </div>
  </section>

  <!-- Education -->
  {resume?.education && resume.education.length > 0 && (
    <section class="py-16 md:py-24 bg-page dark:bg-midnight">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="flex items-center gap-3 mb-10 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <span class="h-px w-12 bg-gradient-to-r from-sapphire to-cyan2"></span>
          <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text">Education</p>
        </div>
        <div class="space-y-6">
          {resume.education.map((edu, index) => (
            <div
              class="premium-card rounded-2xl p-6 md:p-8 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
              style={`animation-delay: ${index * 80}ms;`}
            >
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 mb-4">
                <div>
                  <h3 class="text-xl font-bold text-heading">{edu.school}</h3>
                  <p class="text-base text-muted mt-1">{edu.degree}</p>
                </div>
                {edu.graduationYear && (
                  <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-sapphire/10 text-sapphire dark:text-cyan2 border border-sapphire/10 whitespace-nowrap self-start">
                    <Icon name="tabler:calendar" class="w-3.5 h-3.5" />
                    {edu.graduationYear}
                  </span>
                )}
              </div>
              {edu.coursework && edu.coursework.length > 0 && (
                <div>
                  <p class="text-xs font-semibold text-muted uppercase tracking-wider mb-3">Relevant Coursework</p>
                  <div class="flex flex-wrap gap-2">
                    {edu.coursework.map((course) => (
                      <span class="px-3 py-1 rounded-lg text-xs font-medium bg-section-alt dark:bg-surface text-heading border border-border/40">
                        {course}
                      </span>
                    ))}
                  </div>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Experience -->
  {resume?.experience && resume.experience.length > 0 && (
    <section class="py-16 md:py-24 bg-section-alt dark:bg-midnight">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="flex items-center gap-3 mb-10 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <span class="h-px w-12 bg-gradient-to-r from-sapphire to-cyan2"></span>
          <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text">Experience</p>
        </div>
        <div class="relative">
          <!-- Timeline line -->
          <div class="absolute left-0 md:left-5 top-2 bottom-2 w-px bg-gradient-to-b from-sapphire/40 via-cyan2/20 to-transparent hidden md:block" aria-hidden="true"></div>
          <div class="space-y-8 md:pl-14">
            {resume.experience.map((exp, index) => (
              <div
                class="relative intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
                style={`animation-delay: ${index * 100}ms;`}
              >
                <!-- Timeline dot -->
                <div class="absolute -left-[2.85rem] top-1 hidden md:flex w-4 h-4 rounded-full bg-gradient-to-br from-sapphire to-cyan2 items-center justify-center shadow-md shadow-sapphire/20" aria-hidden="true">
                  <div class="w-2 h-2 rounded-full bg-white/80"></div>
                </div>
                <div class="premium-card-flat rounded-2xl p-6">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
                    <div>
                      <h3 class="text-base font-bold text-heading">{exp.role}</h3>
                      <p class="text-sm text-muted mt-0.5">{exp.company}</p>
                    </div>
                    {(exp.startDate || exp.endDate) && (
                      <span class="text-xs font-medium text-muted whitespace-nowrap self-start mt-0.5">
                        {exp.startDate}{exp.startDate && exp.endDate ? ' — ' : ''}{exp.endDate}
                      </span>
                    )}
                  </div>
                  {exp.description && (
                    <p class="text-sm text-muted leading-relaxed">{exp.description}</p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Skills -->
  {resume?.skills && resume.skills.length > 0 && (
    <section class="py-16 md:py-24 bg-page dark:bg-midnight">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="flex items-center gap-3 mb-10 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <span class="h-px w-12 bg-gradient-to-r from-sapphire to-cyan2"></span>
          <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text">Skills</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-2 gap-5">
          {resume.skills.map((group, index) => (
            <div
              class="premium-card rounded-2xl p-6 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
              style={`animation-delay: ${index * 60}ms;`}
            >
              <div class="flex items-center gap-2 mb-4">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-sapphire/10 to-cyan2/10 flex items-center justify-center">
                  <Icon name="tabler:code" class="w-4 h-4 text-sapphire dark:text-cyan2" />
                </div>
                <h3 class="text-sm font-bold text-heading uppercase tracking-wide">{group.category}</h3>
              </div>
              <div class="flex flex-wrap gap-2">
                {group.items.map((skill) => (
                  <span class="px-3 py-1 rounded-full text-xs font-medium bg-gradient-to-r from-sapphire/8 to-cyan2/8 text-sapphire dark:text-cyan2 border border-sapphire/10 dark:border-cyan2/10">
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Looking For -->
  {resume?.lookingFor && (
    <section class="py-16 md:py-24 bg-section-alt dark:bg-midnight">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="flex items-center gap-3 mb-10 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <span class="h-px w-12 bg-gradient-to-r from-gold to-amber-400"></span>
          <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text-gold">What I'm Looking For</p>
        </div>
        <div class="premium-card rounded-2xl p-8 md:p-10 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <div class="relative">
            <div class="absolute -top-4 -left-1 text-6xl font-serif text-gold/20 select-none leading-none" aria-hidden="true">"</div>
            <p class="relative text-lg md:text-xl text-heading leading-relaxed pl-6 border-l-2 border-gold/40 font-serif italic">
              {resume.lookingFor}
            </p>
            <div class="absolute -bottom-8 -right-1 text-6xl font-serif text-gold/20 select-none leading-none" aria-hidden="true">"</div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-16 md:py-24 bg-page dark:bg-midnight">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
      <p class="text-xs font-bold tracking-[0.2em] uppercase gradient-text mb-3">Opportunities</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tighter text-heading mb-4">Let&apos;s Talk</h2>
      <p class="text-muted text-lg mb-8 leading-relaxed">
        If you think there&apos;s a fit, I&apos;d love to hear from you.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full bg-gradient-to-r from-sapphire to-cyan2 text-white font-semibold hover:shadow-lg hover:shadow-sapphire/20 transition-all"
      >
        <Icon name="tabler:send" class="w-4 h-4" />
        Reach Out
      </a>
    </div>
  </section>
</PageLayout>
